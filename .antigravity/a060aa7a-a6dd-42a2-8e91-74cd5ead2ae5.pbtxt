  file_change {
    absolute_path_uri: "file:///src/App.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useEffect } from \'react\';\nimport { motion, useScroll, useTransform, AnimatePresence } from \'motion/react\';\nimport { \n  Sparkles, Layers, Terminal, BookOpen, Cpu, Download, \n  ArrowRight, ShieldCheck, ChevronDown, Check, Zap, HelpCircle\n} from \'lucide-react\';\nimport { Navigation } from \'./components/Navigation\';\nimport { DAWSimulator } from \'./components/DAWSimulator\';\nimport { DocsSection } from \'./components/DocsSection\';\nimport { AboutSection } from \'./components/AboutSection\';\nimport { SupportSection } from \'./components/SupportSection\';\n\nexport default function App() {\n  const [activeSection, setActiveSection] = useState(\'alan\');\n  const [scrollPercentage, setScrollPercentage] = useState(0);\n\n  // Monitor real-time scroll position to drive visual coordinates and active section spy\n  useEffect(() => {\n    const handleScroll = () => {\n      const scrollY = window.scrollY;\n      const windowHeight = window.innerHeight;\n      const totalHeight = document.documentElement.scrollHeight - windowHeight;\n      \n      // Calculate depth percentage\n      if (totalHeight > 0) {\n        setScrollPercentage(Math.min(100, Math.max(0, (scrollY / totalHeight) * 100)));\n      }\n\n      // Scroll Spy matching ID anchors\n      const sections = [\'alan\', \'docs\', \'about\', \'support\'];\n      let currentActive = \'alan\';\n\n      for (const sectionId of sections) {\n        const el = document.getElementById(`section-${sectionId}`);\n        if (el) {\n          const rect = el.getBoundingClientRect();\n          // If top of section is near the middle of screen\n          if (rect.top <= windowHeight * 0.45 && rect.bottom >= windowHeight * 0.2) {\n            currentActive = sectionId;\n          }\n        }\n      }\n      setActiveSection(currentActive);\n    };\n\n    window.addEventListener(\'scroll\', handleScroll);\n    // Initial run to capture state on mount\n    handleScroll();\n    return () => window.removeEventListener(\'scroll\', handleScroll);\n  }, []);\n\n  const handleScrollToSection = (sectionId: string) => {\n    const el = document.getElementById(`section-${sectionId}`);\n    if (el) {\n      el.scrollIntoView({ behavior: \'smooth\' });\n      setActiveSection(sectionId);\n    }\n  };\n\n  // Compute glowing color shifts based on active sections\n  const getAmbientGlowClass = () => {\n    if (activeSection === \'docs\') return \'from-emerald-500/10 via-cyan-500/5 to-transparent\';\n    if (activeSection === \'about\') return \'from-cyan-500/10 via-purple-500/5 to-transparent\';\n    if (activeSection === \'support\') return \'from-purple-500/10 via-red-500/5 to-transparent\';\n    return \'from-emerald-500/15 via-[#06b6d4]/5 to-transparent\';\n  };\n\n  return (\n    <div className=\"relative min-h-screen bg-[#090a0f] text-zinc-200 selection:bg-emerald-500/30 selection:text-emerald-300\">\n      \n      {/* Absolute cybernetic ambient glowing elements that translate with scroll */}\n      <div className=\"fixed inset-0 pointer-events-none overflow-hidden z-0\">\n        \n        {/* Futuristic background grid lines */}\n        <div className=\"absolute inset-0 bg-grid-cyber opacity-30\"></div>\n        \n        {/* Rotating ambient radial gradients */}\n        <div className={`absolute top-[-10%] left-[10%] w-[60vw] h-[60vw] rounded-full bg-radial transition-all duration-1000 blur-[130px] opacity-40 ${getAmbientGlowClass()}`}></div>\n        <div className=\"absolute bottom-[10%] right-[-10%] w-[50vw] h-[50vw] rounded-full bg-radial from-emerald-500/5 via-transparent to-transparent blur-[120px] opacity-30\"></div>\n        \n        {/* Floating Code Telemetry Stream overlaying right margin */}\n        <div className=\"hidden xl:flex absolute top-24 right-6 flex-col items-end font-mono text-[9px] text-zinc-650 opacity-60 tracking-wider space-y-2 uppercase select-none\">\n          <div className=\"flex items-center space-x-1.5\">\n            <span className=\"text-zinc-500\">SYS_SECTOR:</span>\n            <span className=\"text-[#22c55e] font-bold\">{activeSection.toUpperCase()}</span>\n          </div>\n          <div>CYBER_DEPTH_COORD : {scrollPercentage.toFixed(1)}%</div>\n          <div>MASTER_CLK_RATE : 124.00HZ</div>\n          <div className=\"w-16 h-1 bg-zinc-900 rounded-full overflow-hidden\">\n            <div \n              style={{ width: `${scrollPercentage}%` }} \n              className=\"h-full bg-emerald-500 shadow-[0_0_8px_#10b981] transition-all duration-150\"\n            />\n          </div>\n        </div>\n\n        {/* Floating Socials or Quick Indicators on the left margin */}\n        <div className=\"hidden xl:flex absolute bottom-8 left-8 flex-col space-y-3 font-mono text-[9px] text-zinc-500 select-none\">\n          <div>ALAN ABLETON VST PLUGIN</div>\n          <div>\302\251 {new Date().getFullYear()} ALL RIGHTS RESERVED</div>\n        </div>\n\n      </div>\n\n      {/* Futuristic Floating top navbar */}\n      <Navigation \n        activeSection={activeSection} \n        onNavigate={handleScrollToSection} \n      />\n\n      {/* Main Layout Wrap */}\n      <main className=\"relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pt-16\">\n        \n        {/* =========================================\n            SECTION 1: ALAN (HERO SCREEN & DAW SIMULATOR)\n            ========================================= */}\n        <section \n          id=\"section-alan\" \n          className=\"min-h-[calc(100vh-4rem)] flex flex-col justify-center py-10 lg:py-16 border-b border-obsidian-border\"\n        >\n          {/* Header visual introduction badges */}\n          <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-10 items-center\">\n            \n            {/* Left Hand: High-end display typography claims */}\n            <div className=\"lg:col-span-5 space-y-6\">\n              \n              <div className=\"inline-flex items-center space-x-2 rounded-full border border-emerald-500/30 bg-emerald-950/25 px-3 py-1 text-xs select-none\">\n                <span className=\"h-1.5 w-1.5 rounded-full bg-emerald-400 animate-pulse\"></span>\n                <span className=\"font-mono text-[10px] uppercase font-bold text-emerald-300\">VST HOST CONNECTOR v1.4.2</span>\n              </div>\n\n              <h1 className=\"font-sans text-4xl sm:text-5xl font-black tracking-tight text-white leading-[1.1]\">\n                An Intelligent Assistant Inside <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-cyan-400 text-glow-green\">Ableton Live.</span>\n              </h1>\n\n              <p className=\"text-zinc-400 text-sm leading-relaxed max-w-md\">\n                ALAN is a modular AI integration plug-in that lives directly on your channels. Write questions, arrange progressions, quantize clip notes, and morph effects settings via conversational multi-step text prompts.\n              </p>\n\n              {/* Unique feature checklist highlighting product values */}\n              <div className=\"space-y-3 pt-2\">\n                <div className=\"flex items-start space-x-2.5 text-xs\">\n                  <div className=\"h-4.5 w-4.5 rounded-full bg-emerald-950/20 border border-emerald-500/40 flex items-center justify-center shrink-0 mt-0.5\">\n                    <Check className=\"h-3 w-3 text-emerald-400\" />\n                  </div>\n                  <div>\n                    <span className=\"font-semibold text-zinc-200\">Conversational DAW Control:</span>\n                    <p className=\"text-zinc-400 text-[11px] mt-0.5\">Automate and manipulate synth macros and stock parameters by simply writing commands.</p>\n                  </div>\n                </div>\n\n                <div className=\"flex items-start space-x-2.5 text-xs\">\n                  <div className=\"h-4.5 w-4.5 rounded-full bg-cyan-950/20 border border-cyan-500/40 flex items-center justify-center shrink-0 mt-0.5\">\n                    <Check className=\"h-3 w-3 text-cyan-400\" />\n                  </div>\n                  <div>\n                    <span className=\"font-semibold text-zinc-200\">Generative MIDI Modulators:</span>\n                    <p className=\"text-zinc-400 text-[11px] mt-0.5\">Formulate progressions, adjust swing configurations, and apply scale constraints directly on clips.</p>\n                  </div>\n                </div>\n              </div>\n\n              {/* Primary Call to Action buttons */}\n              <div className=\"flex flex-col sm:flex-row items-stretch sm:items-center space-y-3 sm:space-y-0 sm:space-x-4 pt-4\">\n                <button\n                  onClick={() => {\n                    const el = document.getElementById(\'simulation-anchor\');\n                    if (el) el.scrollIntoView({ behavior: \'smooth\' });\n                  }}\n                  className=\"group flex items-center justify-center space-x-2 rounded-xl bg-emerald-500 hover:bg-emerald-400 px-6 py-3.5 font-mono text-xs font-semibold text-[#090a0f] transition-all hover:shadow-[0_0_15px_rgba(34,197,94,0.45)] cursor-pointer\"\n                >\n                  <span>LAUNCH DAW SIMULATOR</span>\n                  <ArrowRight className=\"h-4 w-4 transition-transform group-hover:translate-x-1\" />\n                </button>\n                \n                <button\n                  onClick={() => handleScrollToSection(\'docs\')}\n                  className=\"flex items-center justify-center space-x-1.5 rounded-xl border border-zinc-800 hover:border-zinc-700 bg-zinc-900/60 hover:bg-zinc-900 px-6 py-3.5 font-mono text-xs font-semibold text-zinc-300 hover:text-white transition-all cursor-pointer\"\n                >\n                  <span>EXPLORE TELEMETRY API</span>\n                </button>\n              </div>\n\n            </div>\n\n            {/* Right Hand: Interactive Ableton + ALAN Simulation workspace */}\n            <div className=\"lg:col-span-7 w-full\">\n              <DAWSimulator />\n            </div>\n\n          </div>\n\n          {/* Scrolling interactive guide indicators */}\n          <div className=\"hidden md:flex flex-col items-center justify-center mt-12 py-4 select-none animate-bounce\">\n            <span className=\"font-mono text-[9px] text-zinc-500 tracking-[0.15em] uppercase pl-1\">SCROLL THROUGH CONTINUUMS FOR DOCUMENTATION</span>\n            <ChevronDown className=\"h-4 w-4 text-emerald-400 mt-1\" />\n          </div>\n\n        </section>\n\n        {/* =========================================\n            SECTION 2: DOCS\n            ========================================= */}\n        <section \n          id=\"section-docs\" \n          className=\"min-h-[calc(100vh-4rem)] flex flex-col justify-center py-16 md:py-24 border-b border-obsidian-border\"\n        >\n          <DocsSection />\n        </section>\n\n        {/* =========================================\n            SECTION 3: ABOUT (ENGINE STACK)\n            ========================================= */}\n        <section \n          id=\"section-about\" \n          className=\"min-h-[calc(100vh-4rem)] flex flex-col justify-center py-16 md:py-24 border-b border-obsidian-border\"\n        >\n          <AboutSection />\n        </section>\n\n        {/* =========================================\n            SECTION 4: SUPPORT (CONTACT CONSOLE)\n            ========================================= */}\n        <section \n          id=\"section-support\" \n          className=\"min-h-[calc(100vh-4rem)] flex flex-col justify-center py-16 md:py-24 pb-20\"\n        >\n          <SupportSection />\n        </section>\n\n      </main>\n\n      {/* Cyber Footer */}\n      <footer className=\"w-full border-t border-obsidian-border bg-[#050609]/95 backdrop-blur shadow-2xl py-8 mt-12\">\n        <div className=\"mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between text-zinc-500 text-xs font-mono\">\n          <div className=\"flex items-center space-x-2 mb-4 sm:mb-0\">\n            <div className=\"flex h-6 w-6 items-center justify-center rounded bg-emerald-950/20 border border-emerald-500/20\">\n              <Sparkles className=\"h-3 w-3 text-emerald-400\" />\n            </div>\n            <span className=\"font-bold tracking-wider text-zinc-400\">ALAN AI SYSTEM // ABLETON PLUGIN</span>\n          </div>\n\n          <div className=\"flex items-center space-x-6\">\n            <span className=\"hover:text-zinc-300 cursor-pointer\" onClick={() => handleScrollToSection(\'alan\')}>Home</span>\n            <span className=\"hover:text-zinc-300 cursor-pointer\" onClick={() => handleScrollToSection(\'docs\')}>Docs</span>\n            <span className=\"hover:text-zinc-300 cursor-pointer\" onClick={() => handleScrollToSection(\'about\')}>Engine</span>\n            <span className=\"hover:text-zinc-300 cursor-pointer\" onClick={() => handleScrollToSection(\'support\')}>Support Portal</span>\n          </div>\n        </div>\n      </footer>\n\n    </div>\n  );\n}\n"
    }
