      target_content: "@import url(\'https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght=0,300;0,400;0,500;0,600;1,400&family=Space+Grotesk:wght@300;400;500;600;700&display=swap\');\n@import \"tailwindcss\";\n\n@theme {\n  --font-sans: \'Space Grotesk\', ui-sans-serif, system-ui, sans-serif;\n  --font-mono: \'JetBrains Mono\', ui-monospace, SFMono-Regular, monospace;\n  \n  --color-neon-green: #22c55e;\n  --color-neon-cyan: #06b6d4;\n  --color-neon-purple: #a855f7;\n  --color-obsidian: #090a0f;\n  --color-obsidian-card: #12141f;\n  --color-obsidian-border: #1f2335;\n}\n\n/* Base custom styles to give the Ableton feeling */\n@layer base {\n  body {\n    background-color: var(--color-obsidian);\n    color: #e2e8f0;\n    font-family: var(--font-sans);\n    overflow-x: hidden;\n  }\n}\n\n/* Custom background grid & glowing designs */\n.bg-grid-cyber {\n  background-size: 40px 40px;\n  background-image: \n    linear-gradient(to right, rgba(32, 36, 53, 0.4) 1px, transparent 1px),\n    linear-gradient(to bottom, rgba(32, 36, 53, 0.4) 1px, transparent 1px);\n}\n\n.glow-cyan {\n  box-shadow: 0 0 20px rgba(6, 182, 212, 0.25);\n}\n\n.glow-green {\n  box-shadow: 0 0 20px rgba(34, 197, 94, 0.25);\n}\n\n.text-glow-green {\n  text-shadow: 0 0 10px rgba(34, 197, 94, 0.6);\n}\n\n.text-glow-cyan {\n  text-shadow: 0 0 10px rgba(6, 182, 212, 0.6);\n}\n\n/* Custom Webkit scrollbar for premium feel */\n::-webkit-scrollbar {\n  width: 8px;\n  height: 8px;\n}\n\n::-webkit-scrollbar-track {\n  background: var(--color-obsidian);\n}\n\n::-webkit-scrollbar-thumb {\n  background: #1f2335;\n  border-radius: 4px;\n}\n\n::-webkit-scrollbar-thumb:hover {\n  background: #2e344e;\n}\n\n/* Glow lines */\n.border-glow-green {\n  border-color: rgba(34, 197, 94, 0.3);\n  box-shadow: 0 0 10px rgba(34, 197, 94, 0.1);\n}\n\n.border-glow-cyan {\n  border-color: rgba(6, 182, 212, 0.3);\n  box-shadow: 0 0 10px rgba(6, 182, 212, 0.1);\n}"
      replacement_content: "@import url(\'https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght=0,300;0,400;0,500;0,600;1,400&family=Space+Grotesk:wght@300;400;500;600;700&display=swap\');\n@import \"tailwindcss\";\n\n@theme {\n  --font-sans: \'Space Grotesk\', ui-sans-serif, system-ui, sans-serif;\n  --font-mono: \'JetBrains Mono\', ui-monospace, SFMono-Regular, monospace;\n  \n  --color-neon-cyan: #06b6d4;\n  --color-neon-purple: #a855f7;\n  --color-obsidian: #050505;\n  --color-obsidian-card: #0f0f0f;\n  --color-obsidian-border: rgba(255, 255, 255, 0.08);\n}\n\n/* Base custom styles for clean modern interface */\n@layer base {\n  body {\n    background-color: var(--color-obsidian);\n    color: #e2e8f0;\n    font-family: var(--font-sans);\n    overflow-x: hidden;\n  }\n}\n\n/* Custom background grid & glowing designs */\n.bg-grid-cyber {\n  background-size: 32px 32px;\n  background-image: \n    linear-gradient(to right, rgba(255, 255, 255, 0.02) 1px, transparent 1px),\n    linear-gradient(to bottom, rgba(255, 255, 255, 0.02) 1px, transparent 1px);\n}\n\n.glow-cyan {\n  box-shadow: 0 0 25px rgba(6, 182, 212, 0.15);\n}\n\n.glow-purple {\n  box-shadow: 0 0 25px rgba(168, 85, 247, 0.15);\n}\n\n.text-glow-cyan {\n  text-shadow: 0 0 10px rgba(6, 182, 212, 0.5);\n}\n\n.text-glow-purple {\n  text-shadow: 0 0 10px rgba(168, 85, 247, 0.5);\n}\n\n/* Custom Webkit scrollbar for premium feel */\n::-webkit-scrollbar {\n  width: 6px;\n  height: 6px;\n}\n\n::-webkit-scrollbar-track {\n  background: var(--color-obsidian);\n}\n\n::-webkit-scrollbar-thumb {\n  background: rgba(255, 255, 255, 0.1);\n  border-radius: 9999px;\n}\n\n::-webkit-scrollbar-thumb:hover {\n  background: rgba(255, 255, 255, 0.2);\n}\n\n/* Glow lines */\n.border-glow-cyan {\n  border-color: rgba(6, 182, 212, 0.25);\n  box-shadow: 0 0 8px rgba(6, 182, 212, 0.08);\n}\n\n.border-glow-purple {\n  border-color: rgba(168, 85, 247, 0.25);\n  box-shadow: 0 0 8px rgba(168, 85, 247, 0.08);\n}"
    }
