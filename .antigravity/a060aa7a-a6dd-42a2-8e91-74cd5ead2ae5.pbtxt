    replacement_chunks {
      target_content: "import React from \'react\';\nimport { Sparkles, Download, Terminal, Settings } from \'lucide-react\';\n\ninterface NavigationProps {\n  activeSection: string;\n  onNavigate: (sectionId: string) => void;\n}\n\nexport function Navigation({ activeSection, onNavigate }: NavigationProps) {\n  const navItems = [\n    { id: \'alan\', label: \'ALAN AI\' },\n    { id: \'docs\', label: \'Documentation\' },\n    { id: \'about\', label: \'About Engine\' },\n    { id: \'support\', label: \'Producer Support\' }\n  ];\n\n  return (\n    <header className=\"fixed top-0 left-0 right-0 z-50 h-16 border-b border-obsidian-border bg-[#090a0f]/85 backdrop-blur-md\">\n      <div className=\"mx-auto flex h-full max-w-7xl items-center justify-between px-6\">\n        {/* Logo Section */}\n        <div \n          onClick={() => onNavigate(\'alan\')}\n          className=\"flex cursor-pointer items-center space-x-2 group\"\n        >\n          <div className=\"relative flex h-9 w-9 items-center justify-center rounded-lg border border-emerald-500/30 bg-emerald-950/25 transition-all group-hover:border-emerald-400 group-hover:shadow-[0_0_15px_rgba(52,211,153,0.3)]\">\n            <Sparkles className=\"h-4.5 w-4.5 text-emerald-400 transition-transform group-hover:rotate-12\" />\n            <div className=\"absolute -inset-0.5 -z-10 rounded-lg bg-emerald-500/10 opacity-0 blur group-hover:opacity-100 transition-opacity\"></div>\n          </div>\n          <div className=\"flex flex-col\">\n            <span className=\"font-mono text-xs font-bold tracking-[0.2em] text-white\">ALAN // AI</span>\n            <span className=\"font-mono text-[9px] text-zinc-500 tracking-wider\">ABLETON INTEGRATOR v1.4.2</span>\n          </div>\n        </div>\n\n        {/* Center Nav Items */}\n        <nav className=\"hidden md:flex items-center space-x-1\">\n          {navItems.map((item) => {\n            const isActive = activeSection === item.id;\n            return (\n              <button\n                key={item.id}\n                onClick={() => onNavigate(item.id)}\n                className={`relative px-4 py-2 font-mono text-xs font-medium tracking-wide transition-all rounded-md ${\n                  isActive \n                    ? \'text-emerald-400\' \n                    : \'text-zinc-400 hover:text-white hover:bg-zinc-900/40\'\n                }`}\n              >\n                {item.label}\n                {isActive && (\n                  <span className=\"absolute bottom-0 left-4 right-4 h-0.5 bg-emerald-500 shadow-[0_0_8px_#10b981]\" />\n                )}\n              </button>\n            );\n          })}\n        </nav>\n\n        {/* Right Action Button */}\n        <div className=\"flex items-center space-x-4\">\n          <button \n            onClick={() => {\n              const el = document.getElementById(\'support-form-anchor\');\n              if (el) el.scrollIntoView({ behavior: \'smooth\' });\n            }}\n            className=\"hidden sm:flex items-center space-x-1.5 font-mono text-[10px] text-zinc-400 hover:text-zinc-200\"\n          >\n            <Settings className=\"h-3.5 w-3.5 animate-spin-slow text-cyan-400\" />\n            <span>CONNECT HOST</span>\n          </button>\n          \n          <button \n            onClick={() => alert(\"Downloading ALAN VST plugin package for Ableton Live Suite (v11/v12) for macOS / Windows. (Simulated)\")}\n            className=\"flex items-center space-x-2 rounded-md bg-emerald-500 hover:bg-emerald-400 px-4 py-2 font-mono text-xs font-semibold text-[#090a0f] transition-all hover:shadow-[0_0_15px_rgba(34,197,94,0.4)] cursor-pointer\"\n          >\n            <Download className=\"h-3.5 w-3.5\" />\n            <span>INSTALL PLUGIN</span>\n          </button>\n        </div>\n      </div>\n    </header>\n  );\n}"
      replacement_content: "import React from \'react\';\nimport { Sparkles, Download, Terminal, Settings } from \'lucide-react\';\n\ninterface NavigationProps {\n  activeSection: string;\n  onNavigate: (sectionId: string) => void;\n}\n\nexport function Navigation({ activeSection, onNavigate }: NavigationProps) {\n  const navItems = [\n    { id: \'alan\', label: \'ALAN AI\' },\n    { id: \'docs\', label: \'Documentation\' },\n    { id: \'about\', label: \'About Engine\' },\n    { id: \'support\', label: \'Producer Support\' }\n  ];\n\n  return (\n    <header className=\"fixed top-0 left-0 right-0 z-50 h-16 border-b border-white/5 bg-[#050505]/80 backdrop-blur-md\">\n      <div className=\"mx-auto flex h-full max-w-7xl items-center justify-between px-6\">\n        {/* Logo Section */}\n        <div \n          onClick={() => onNavigate(\'alan\')}\n          className=\"flex cursor-pointer items-center space-x-2 group\"\n        >\n          <div className=\"relative flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-tr from-cyan-400 to-purple-500 transition-all group-hover:shadow-[0_0_15px_rgba(6,182,212,0.4)]\">\n            <span className=\"text-black font-black text-xs font-mono\">A</span>\n          </div>\n          <div className=\"flex flex-col\">\n            <span className=\"font-mono text-xs font-bold tracking-[0.2em] text-white\">ALAN<span className=\"text-cyan-400\">.</span></span>\n            <span className=\"font-mono text-[9px] text-zinc-500 tracking-wider\">ABLETON INTEGRATOR v1.4.2</span>\n          </div>\n        </div>\n\n        {/* Center Nav Items */}\n        <nav className=\"hidden md:flex items-center space-x-1\">\n          {navItems.map((item) => {\n            const isActive = activeSection === item.id;\n            return (\n              <button\n                key={item.id}\n                onClick={() => onNavigate(item.id)}\n                className={`relative px-4 py-2 font-mono text-xs font-medium tracking-wide transition-all rounded-md ${\n                  isActive \n                    ? \'text-cyan-400 font-bold\' \n                    : \'text-zinc-400 hover:text-white hover:bg-white/5\'\n                }`}\n              >\n                {item.label}\n                {isActive && (\n                  <span className=\"absolute bottom-0 left-4 right-4 h-0.5 bg-gradient-to-r from-cyan-400 to-purple-500 shadow-[0_0_8px_rgba(6,182,212,0.6)]\" />\n                )}\n              </button>\n            );\n          })}\n        </nav>\n\n        {/* Right Action Button */}\n        <div className=\"flex items-center space-x-4\">\n          <button \n            onClick={() => {\n              const el = document.getElementById(\'support-form-anchor\');\n              if (el) el.scrollIntoView({ behavior: \'smooth\' });\n            }}\n            className=\"hidden sm:flex items-center space-x-1.5 font-mono text-[10px] text-zinc-400 hover:text-zinc-200\"\n          >\n            <Settings className=\"h-3.5 w-3.5 animate-spin-slow text-purple-400\" />\n            <span>CONNECT HOST</span>\n          </button>\n          \n          <button \n            onClick={() => alert(\"Downloading ALAN VST plugin package for Ableton Live Suite (v11/v12) for macOS / Windows. (Simulated)\")}\n            className=\"flex items-center space-x-2 rounded-full bg-white text-black text-xs font-bold uppercase tracking-widest hover:bg-cyan-400 transition-all px-5 py-2 cursor-pointer shadow-md\"\n          >\n            <Download className=\"h-3 w-3 inline text-black\" />\n            <span>INSTALL PLUGIN</span>\n          </button>\n        </div>\n      </div>\n    </header>\n  );\n}"
    }
