    instruction: "Make SupportSection sleek, minimalist, and ultra-high-end"
    replacement_infos {
      original_chunk {
        target_content: "      {/* Title block */}\n      <div className=\"flex items-center space-x-2.5 mb-8\">\n        <div className=\"flex h-8 w-8 items-center justify-center rounded-lg bg-zinc-950 border border-cyan-500/30\">\n          <Terminal className=\"h-4.5 w-4.5 text-cyan-400\" />\n        </div>\n        <div className=\"flex flex-col\">\n          <span className=\"font-mono text-xs font-bold tracking-[0.2em] text-cyan-400 uppercase\">SUPPORT HUB</span>\n          <h2 className=\"font-sans text-2xl font-bold tracking-tight text-white\">Producer Support Console</h2>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start\">\n        \n        {/* Left Hand: Glassmorphic interactive form - 6 Columns */}\n        <div className=\"lg:col-span-7\">\n          <div className=\"p-6 md:p-8 rounded-2xl border border-obsidian-border bg-[#11141e]/50 backdrop-blur-sm shadow-xl\">\n            \n            {!isSubmitted ? (\n              <form onSubmit={handleFormSubmit} className=\"space-y-5\">\n                <div className=\"flex flex-col\">\n                  <h3 className=\"font-sans text-lg font-bold text-white mb-1.5\">Open a Support Telemetry Node</h3>\n                  <p className=\"text-zinc-400 text-xs\">\n                    Need help setting up the VST, licensing, or mapping macros in Ableton? Submit a feedback ticket and our neural tech drone team will contact you back immediately.\n                  </p>\n                </div>\n\n                <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                  {/* Name Input */}\n                  <div className=\"space-y-1.5\">\n                    <label className=\"font-mono text-[10px] text-zinc-500 font-bold uppercase tracking-widest pl-1\">PRODUCER NAME</label>\n                    <input\n                      type=\"text\"\n                      name=\"name\"\n                      required\n                      value={ticket.name}\n                      onChange={handleInputChange}\n                      placeholder=\"e.g. Mike Shinoda\"\n                      disabled={isSubmitting}\n                      className=\"w-full bg-[#050505] border border-zinc-850 focus:border-cyan-500 rounded-xl py-3 px-4 text-xs font-mono text-zinc-100 placeholder-zinc-650 outline-none transition-all focus:ring-1 focus:ring-cyan-500/35\"\n                    />\n                  </div>\n\n                  {/* Email Input */}\n                  <div className=\"space-y-1.5\">\n                    <label className=\"font-mono text-[10px] text-zinc-500 font-bold uppercase tracking-widest pl-1\">EMAIL SIGNAL ADDRESS</label>\n                    <input\n                      type=\"email\"\n                      name=\"email\"\n                      required\n                      value={ticket.email}\n                      onChange={handleInputChange}\n                      placeholder=\"e.g. mike@linkinpark.com\"\n                      disabled={isSubmitting}\n                      className=\"w-full bg-[#050505] border border-zinc-850 focus:border-cyan-500 rounded-xl py-3 px-4 text-xs font-mono text-zinc-100 placeholder-zinc-650 outline-none transition-all focus:ring-1 focus:ring-cyan-500/35\"\n                    />\n                  </div>\n                </div>\n\n                {/* Issue Type */}\n                <div className=\"space-y-1.5\">\n                  <label className=\"font-mono text-[10px] text-zinc-500 font-bold uppercase tracking-widest pl-1\">DIAGNOSTIC CLASS CATEGORY</label>\n                  <select\n                    name=\"issueType\"\n                    value={ticket.issueType}\n                    onChange={handleInputChange}\n                    disabled={isSubmitting}\n                    className=\"w-full bg-[#050505] border border-zinc-850 focus:border-cyan-555 rounded-xl py-3 px-4 text-xs font-mono text-zinc-300 outline-none transition-all focus:ring-1 focus:ring-cyan-555/35\"\n                  >\n                    <option value=\"plugin_bug\">VST Plugin Bug Exception</option>\n                    <option value=\"api_key\">AI API Credentials / Licensing Setup</option>\n                    <option value=\"feature_request\">Telemetry Command Suggestion</option>\n                    <option value=\"general\">Generic Ableton Mapping Assistance</option>\n                  </select>\n                </div>\n\n                {/* Message Body Input */}\n                <div className=\"space-y-1.5\">\n                  <label className=\"font-mono text-[10px] text-zinc-500 font-bold uppercase tracking-widest pl-1\">EXPLANATION TELEMETRY PAYLOAD</label>\n                  <textarea\n                    name=\"message\"\n                    required\n                    rows={4}\n                    value={ticket.message}\n                    onChange={handleInputChange}\n                    placeholder=\"Describe specific crashes, environment setups, or mapping issues you\'re facing...\"\n                    disabled={isSubmitting}\n                    className=\"w-full bg-[#050505] border border-zinc-850 focus:border-cyan-500 rounded-xl py-3 px-4 text-xs font-mono text-zinc-100 placeholder-zinc-650 outline-none transition-all focus:ring-1 focus:ring-cyan-500/35 resize-none\"\n                  />\n                </div>\n\n                {/* Submit button */}\n                <button\n                  type=\"submit\"\n                  disabled={isSubmitting}\n                  className=\"w-full relative flex items-center justify-center space-x-2 rounded-full bg-white hover:bg-cyan-400 py-3.5 px-6 font-mono text-xs font-bold uppercase tracking-widest text-black transition-all hover:shadow-[0_0_15px_rgba(6,182,212,0.45)] cursor-pointer disabled:opacity-50\"\n                >\n                  <Send className=\"h-3 w-3 inline text-black\" />\n                  <span>TRANSMIT TICKET PAYLOAD</span>\n                </button>\n              </form>\n            ) : (\n              <div className=\"text-center py-6 flex flex-col items-center space-y-4\">\n                <div className=\"h-16 w-16 rounded-full border border-cyan-500 bg-zinc-950 text-cyan-400 flex items-center justify-center animate-bounce\">\n                  <CheckCircle className=\"h-8 w-8 stroke-[1.5px]\" />\n                </div>\n                <div className=\"space-y-2\">\n                  <h3 className=\"font-sans text-xl font-bold text-white\">Transmission Successful</h3>\n                  <p className=\"text-zinc-400 text-xs max-w-sm mx-auto leading-relaxed\">\n                    Producer ticket sent successfully! A confirmation code has been generated and printed on your local terminal console log. Our developer support team will send an email back to <span className=\"text-cyan-400 font-mono font-semibold\">{ticket.email}</span> within 24 standard earth cycles.\n                  </p>\n                </div>\n                <button\n                  onClick={handleResetForm}\n                  className=\"rounded-lg bg-zinc-900 border border-zinc-800 hover:border-zinc-700 hover:text-white px-4 py-2 font-mono text-xs text-zinc-400 cursor-pointer\"\n                >\n                  Create Another Ticket\n                </button>\n              </div>\n            )}\n\n          </div>\n        </div>\n\n        {/* Right Hand: Interactive live terminal viewer - 5 Columns */}\n        <div className=\"lg:col-span-5 flex flex-col h-full lg:sticky lg:top-24\">\n          <span className=\"font-mono text-[10px] text-zinc-500 font-bold uppercase tracking-widest pl-2 mb-2.5\">LIVE TERMINAL TELEMETRY LOGGER</span>\n          \n          <div className=\"flex-grow flex flex-col rounded-2xl border border-obsidian-border bg-black/85 backdrop-blur-sm overflow-hidden shadow-2xl min-h-[300px] max-h-[420px]\">\n            {/* Terminal Header */}\n            <div className=\"flex h-10 w-full items-center justify-between bg-zinc-950 px-4 border-b border-zinc-900 select-none\">\n              <div className=\"flex items-center space-x-1.5\">\n                <div className=\"h-2 w-2 rounded-full bg-red-500\"></div>\n                <div className=\"h-2 w-2 rounded-full bg-yellow-500\"></div>\n                <div className=\"h-2 w-2 rounded-full bg-green-500\"></div>\n                <span className=\"font-mono text-[10px] text-zinc-500 pl-2\">bash - support_uplink.sh</span>\n              </div>\n              <Cpu className=\"h-3.5 w-3.5 text-zinc-500\" />\n            </div>\n\n            {/* Terminal screen content scrolling */}\n            <div className=\"flex-grow p-4 overflow-y-auto font-mono text-[10px] text-zinc-400 space-y-2.5 scrollbar-thin select-text\">\n              {terminalLogs.map((log, idx) => {\n                const isErr = log.toLowerCase().includes(\'err\');\n                const isSuccess = log.toLowerCase().includes(\'success\');\n                const isIntro = idx === 0;\n\n                return (\n                  <div key={idx} className=\"leading-relaxed\">\n                    <span className=\"text-zinc-650 pr-2\">producer@vst_client:~$</span>\n                    <span className={\n                      isIntro \n                        ? \'text-zinc-500\' \n                        : isSuccess\n                          ? \'text-cyan-400 font-bold\'\n                          : isErr\n                            ? \'text-red-400 font-semibold\'\n                            : \'text-zinc-300\'\n                    }>\n                      {log}\n                    </span>\n                  </div>\n                );\n              })}\n              \n              {isSubmitting && (\n                <div className=\"flex items-center space-x-1\">\n                  <span className=\"text-zinc-650 pr-2\">producer@vst_client:~$</span>\n                  <span className=\"text-cyan-400 animate-pulse font-bold uppercase\">UPLINK TRANSMITTING IN PROGRESS...</span>\n                </div>\n              )}"
        replacement_content: "      {/* Title block */}\n      <div className=\"flex items-center space-x-3 mb-10\">\n        <div className=\"flex h-7 w-7 items-center justify-center rounded-sm bg-zinc-950 border border-white/5\">\n          <Terminal className=\"h-3.5 w-3.5 text-cyan-400\" />\n        </div>\n        <div className=\"flex flex-col\">\n          <span className=\"font-mono text-[9px] font-medium tracking-[0.3em] text-cyan-400 uppercase\">SUPPORT HUB</span>\n          <h2 className=\"font-sans text-2xl font-light tracking-tight text-white\">Producer Support Console</h2>\n        </div>\n      </div>\n\n      <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-start\">\n        \n        {/* Left Hand: Glassmorphic interactive form - 6 Columns */}\n        <div className=\"lg:col-span-7\">\n          <div className=\"p-6 md:p-8 rounded-2xl border border-white/5 bg-transparent shadow-xl\">\n            \n            {!isSubmitted ? (\n              <form onSubmit={handleFormSubmit} className=\"space-y-5\">\n                <div className=\"flex flex-col\">\n                  <h3 className=\"font-sans text-xl font-light text-white mb-2\">Open a Support Telemetry Node</h3>\n                  <p className=\"text-zinc-500 text-xs font-light leading-relaxed\">\n                    Need help setting up the VST, licensing, or mapping macros in Ableton? Submit a feedback ticket and our neural tech drone team will contact you back immediately.\n                  </p>\n                </div>\n\n                <div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">\n                  {/* Name Input */}\n                  <div className=\"space-y-1.5\">\n                    <label className=\"font-mono text-[8px] text-zinc-650 font-bold uppercase tracking-widest pl-1\">PRODUCER NAME</label>\n                    <input\n                      type=\"text\"\n                      name=\"name\"\n                      required\n                      value={ticket.name}\n                      onChange={handleInputChange}\n                      placeholder=\"e.g. Mike Shinoda\"\n                      disabled={isSubmitting}\n                      className=\"w-full bg-zinc-950 border border-white/5 focus:border-cyan-500/50 rounded-lg py-2.5 px-3.5 text-[11px] font-mono text-zinc-100 placeholder-zinc-700 outline-none transition-all\"\n                    />\n                  </div>\n\n                  {/* Email Input */}\n                  <div className=\"space-y-1.5\">\n                    <label className=\"font-mono text-[8px] text-zinc-650 font-bold uppercase tracking-widest pl-1\">EMAIL SIGNAL ADDRESS</label>\n                    <input\n                      type=\"email\"\n                      name=\"email\"\n                      required\n                      value={ticket.email}\n                      onChange={handleInputChange}\n                      placeholder=\"e.g. mike@linkinpark.com\"\n                      disabled={isSubmitting}\n                      className=\"w-full bg-zinc-950 border border-white/5 focus:border-cyan-500/50 rounded-lg py-2.5 px-3.5 text-[11px] font-mono text-zinc-100 placeholder-zinc-700 outline-none transition-all\"\n                    />\n                  </div>\n                </div>\n\n                {/* Issue Type */}\n                <div className=\"space-y-1.5\">\n                  <label className=\"font-mono text-[8px] text-zinc-650 font-bold uppercase tracking-widest pl-1\">DIAGNOSTIC CLASS CATEGORY</label>\n                  <select\n                    name=\"issueType\"\n                    value={ticket.issueType}\n                    onChange={handleInputChange}\n                    disabled={isSubmitting}\n                    className=\"w-full bg-zinc-950 border border-white/5 focus:border-cyan-500/50 rounded-lg py-2.5 px-3.5 text-[11px] font-mono text-zinc-300 outline-none transition-all cursor-pointer\"\n                  >\n                    <option value=\"plugin_bug\">VST Plugin Bug Exception</option>\n                    <option value=\"api_key\">AI API Credentials / Licensing Setup</option>\n                    <option value=\"feature_request\">Telemetry Command Suggestion</option>\n                    <option value=\"general\">Generic Ableton Mapping Assistance</option>\n                  </select>\n                </div>\n\n                {/* Message Body Input */}\n                <div className=\"space-y-1.5\">\n                  <label className=\"font-mono text-[8px] text-zinc-650 font-bold uppercase tracking-widest pl-1\">EXPLANATION TELEMETRY PAYLOAD</label>\n                  <textarea\n                    name=\"message\"\n                    required\n                    rows={4}\n                    value={ticket.message}\n                    onChange={handleInputChange}\n                    placeholder=\"Describe specific crashes, environment setups, or mapping issues you\'re facing...\"\n                    disabled={isSubmitting}\n                    className=\"w-full bg-zinc-950 border border-white/5 focus:border-cyan-500/50 rounded-lg py-2.5 px-3.5 text-[11px] font-mono text-zinc-100 placeholder-zinc-700 outline-none transition-all resize-none\"\n                  />\n                </div>\n\n                {/* Submit button */}\n                <button\n                  type=\"submit\"\n                  disabled={isSubmitting}\n                  className=\"w-full relative flex items-center justify-center space-x-2 rounded-full bg-white hover:bg-zinc-100 py-3 px-6 font-mono text-[10px] font-bold uppercase tracking-widest text-black transition-all duration-300 hover:shadow-[0_0_20px_rgba(255,255,255,0.15)] cursor-pointer disabled:opacity-50\"\n                >\n                  <Send className=\"h-2.5 w-2.5 inline text-black\" />\n                  <span>TRANSMIT TICKET PAYLOAD</span>\n                </button>\n              </form>\n            ) : (\n              <div classNa